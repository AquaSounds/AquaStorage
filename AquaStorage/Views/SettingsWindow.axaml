<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:h="clr-namespace:AquaStorage.Helpers"
        x:Class="AquaStorage.Views.SettingsWindow"
        Title="{x:Static h:Localizer.Settings}" Width="600" Height="480"
        WindowStartupLocation="CenterOwner"
        TransparencyLevelHint="Mica"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="0"
        Background="Transparent">
    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Height="32" Background="Transparent"
                PointerPressed="OnTopBarPointerPressed">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{x:Static h:Localizer.Settings}" VerticalAlignment="Center"
                           Margin="12,0,0,0" Opacity="0.6" FontSize="13"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <Button Classes="window-btn" Click="OnMinimize" ToolTip.Tip="{x:Static h:Localizer.Minimize}">
                        <i:Icon Value="mdi-window-minimize" FontSize="14"/>
                    </Button>
                    <Button Classes="window-btn" Click="OnMaximize" ToolTip.Tip="{x:Static h:Localizer.Maximize}">
                        <i:Icon Value="mdi-window-maximize" FontSize="14"/>
                    </Button>
                    <Button Classes="window-btn close-btn" Click="OnClose" ToolTip.Tip="{x:Static h:Localizer.Close}">
                        <i:Icon Value="mdi-window-close" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab content -->
        <TabControl Margin="10,0,10,10">

            <!-- Folders tab -->
            <TabItem Header="{x:Static h:Localizer.TabFolders}">
                <DockPanel Margin="0,8,0,0" LastChildFill="True">
                    <!-- App Data folder path -->
                    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,10">
                        <TextBlock Text="{x:Static h:Localizer.AppData}" Opacity="0.6" FontSize="12"/>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4">
                            <TextBox x:Name="ConfigPathBox" Grid.Column="0"
                                     Watermark="{x:Static h:Localizer.WatermarkAppDataPath}"
                                     IsReadOnly="True"/>
                            <Button x:Name="OpenFolderBtn" Grid.Column="1" Width="40"
                                    Click="OpenFolderBtn_Click"
                                    ToolTip.Tip="{x:Static h:Localizer.OpenFolder}">
                                <i:Icon Value="mdi-folder-open"/>
                            </Button>
                            <Button x:Name="BrowseConfigBtn" Grid.Column="2" Width="40"
                                    Click="BrowseConfigBtn_Click"
                                    ToolTip.Tip="{x:Static h:Localizer.SetFolderLocation}">
                                <i:Icon Value="mdi-cog"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Search box -->
                    <TextBox DockPanel.Dock="Top" x:Name="SearchBox"
                             Watermark="{x:Static h:Localizer.WatermarkSearchPaths}" Margin="0,0,0,8"
                             TextChanged="SearchBox_TextChanged"/>

                    <!-- Path list -->
                    <ListBox x:Name="PathListBox">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock x:Name="PathText" Text="{Binding}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4 0"/>
                                    <Button x:Name="DeleteBtn" Grid.Column="1" Width="80" Margin="4 0"
                                            Click="DeleteBtn_Click"
                                            ToolTip.Tip="{x:Static h:Localizer.Delete}">
                                        <i:Icon Value="mdi-trash-can"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>

            <!-- Appearance tab -->
            <TabItem Header="{x:Static h:Localizer.TabAppearance}">
                <StackPanel Spacing="12" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static h:Localizer.LightTheme}" Opacity="0.6" FontSize="12"
                                   VerticalAlignment="Center" Width="100"/>
                        <ToggleSwitch x:Name="ThemeToggle"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static h:Localizer.ThemeColor}" Opacity="0.6" FontSize="12"
                                   VerticalAlignment="Center" Width="100"/>
                        <Button x:Name="ThemeColorBtn" Click="ThemeColorBtn_Click"
                                ToolTip.Tip="{x:Static h:Localizer.ThemeColor}">
                            <i:Icon Value="mdi-palette"/>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static h:Localizer.FontSize}" Opacity="0.6" FontSize="12"
                                   VerticalAlignment="Center" Width="100"/>
                        <TextBox x:Name="DefaultFontSizeBox" Width="80" Watermark="12"
                                 TextChanged="DefaultFontSizeBox_TextChanged"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static h:Localizer.Language}" Opacity="0.6" FontSize="12"
                                   VerticalAlignment="Center" Width="100"/>
                        <ComboBox x:Name="LanguageCombo" Width="160"
                                  SelectionChanged="LanguageCombo_SelectionChanged"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Storage tab -->
            <TabItem Header="{x:Static h:Localizer.TabStorage}">
                <StackPanel Spacing="12" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static h:Localizer.MaxCache}" Opacity="0.6" FontSize="12"
                                   VerticalAlignment="Center" Width="100"/>
                        <TextBox x:Name="MaxCacheBox" Width="120" Watermark="{x:Static h:Localizer.WatermarkCacheSize}"
                                 TextChanged="MaxCacheBox_TextChanged"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static h:Localizer.ClearCache}" Opacity="0.6" FontSize="12"
                                   VerticalAlignment="Center" Width="100"/>
                        <Button x:Name="ClearCacheBtn" Click="ClearCacheBtn_Click"
                                ToolTip.Tip="{x:Static h:Localizer.ClearCache}">
                            <i:Icon Value="mdi-broom"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
    <Window.Styles>
        <Style Selector="Button.window-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>
        <Style Selector="Button.window-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#20FFFFFF"/>
        </Style>
        <Style Selector="Button.close-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123"/>
        </Style>
    </Window.Styles>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        x:Class="AquaStorage.Views.SettingsWindow"
        Title="Settings" Width="600" Height="440"
        WindowStartupLocation="CenterOwner"
        TransparencyLevelHint="Mica"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="0"
        Background="Transparent">
    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Height="32" Background="Transparent"
                PointerPressed="OnTopBarPointerPressed">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Settings" VerticalAlignment="Center"
                           Margin="12,0,0,0" Opacity="0.6" FontSize="13"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <Button Classes="window-btn" Click="OnMinimize" ToolTip.Tip="Minimize">
                        <i:Icon Value="mdi-window-minimize" FontSize="14"/>
                    </Button>
                    <Button Classes="window-btn" Click="OnMaximize" ToolTip.Tip="Maximize">
                        <i:Icon Value="mdi-window-maximize" FontSize="14"/>
                    </Button>
                    <Button Classes="window-btn close-btn" Click="OnClose" ToolTip.Tip="Close">
                        <i:Icon Value="mdi-window-close" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <DockPanel Margin="10" LastChildFill="True">
            <!-- App Data folder path -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,10">
                <TextBlock Text="App Data" Opacity="0.6" FontSize="12"/>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4">
                    <TextBox x:Name="ConfigPathBox" Grid.Column="0"
                             Watermark="App data folder path"
                             IsReadOnly="True"/>
                    <Button x:Name="OpenFolderBtn" Grid.Column="1" Width="40"
                            Click="OpenFolderBtn_Click"
                            ToolTip.Tip="Open folder">
                        <i:Icon Value="mdi-folder-open"/>
                    </Button>
                    <Button x:Name="BrowseConfigBtn" Grid.Column="2" Width="40"
                            Click="BrowseConfigBtn_Click"
                            ToolTip.Tip="Set folder location">
                        <i:Icon Value="mdi-cog"/>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Search box -->
            <TextBox DockPanel.Dock="Top" x:Name="SearchBox"
                     Watermark="Search paths..." Margin="0,0,0,8"
                     TextChanged="SearchBox_TextChanged"/>

            <!-- Bottom buttons -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Font Size" Opacity="0.6" FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="DefaultFontSizeBox" Width="50" Watermark="12"
                             TextChanged="DefaultFontSizeBox_TextChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Max Cache" Opacity="0.6" FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxCacheBox" Width="80" Watermark="500MB"
                             TextChanged="MaxCacheBox_TextChanged"/>
                </StackPanel>
                <Button x:Name="ClearCacheBtn" Click="ClearCacheBtn_Click"
                        ToolTip.Tip="Clear Cache">
                    <i:Icon Value="fa-solid fa-broom"/>
                </Button>
                <Button x:Name="ThemeColorBtn" Click="ThemeColorBtn_Click"
                        ToolTip.Tip="Theme Color">
                    <i:Icon Value="mdi-palette"/>
                </Button>
            </StackPanel>

            <!-- Path list -->
            <ListBox x:Name="PathListBox">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock x:Name="PathText" Text="{Binding}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="4 0"/>
                            <Button x:Name="DeleteBtn" Grid.Column="1" Width="80" Margin="4 0"
                                    Click="DeleteBtn_Click"
                                    ToolTip.Tip="Delete">
                                <i:Icon Value="mdi-trash-can"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </DockPanel>
    <Window.Styles>
        <Style Selector="Button.window-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>
        <Style Selector="Button.window-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#20FFFFFF"/>
        </Style>
        <Style Selector="Button.close-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123"/>
        </Style>
    </Window.Styles>
</Window>

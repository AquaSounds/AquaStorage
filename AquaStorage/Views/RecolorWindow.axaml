<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AquaStorage.Views"
        x:Class="AquaStorage.Views.RecolorWindow"
        Title="Theme Color" Width="380" Height="480"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="12" Spacing="10">
        <views:AquaColorPicker x:Name="MyColorPicker" Height="300" Width="300"/>
        <StackPanel Orientation="Horizontal" Spacing="80" HorizontalAlignment="Center" Margin="0 8 0 0">
            <Button x:Name="SubmitBtn" Content="Confirm" Width="80" Click="SubmitBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Cancel" Width="80" Click="CancelBtn_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
